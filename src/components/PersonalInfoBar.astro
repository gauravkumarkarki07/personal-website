---
import { cn } from "../utils/cn";

interface NavItems {
  title: string;
  link: string;
}

const navItems: NavItems[] = [
  {
    title: "Professional Experience",
    link: "/experience",
  },
  {
    title: "Education",
    link: "/education",
  },
];
---

<div class="flex flex-col gap-12 h-full w-full">
  <article class="flex flex-col gap-4">
    <h1 class="font-semibold text-5xl">Gaurav Kumar Karki</h1>
    <p class="text-3xl flex flex-col gap-2">
      <span class="text-text-muted">Software Engineer</span>
      <span class="text-xl text-text-muted/70">Melbourne</span>
    </p>
  </article>

  <section class="text-2xl flex flex-col gap-8 text-text-muted">
    {
      navItems.map((item) => (
        <a
          href={item.link}
          class={cn(
            "flex flex-row gap-4 items-center leading-none hover:text-white"
          )}
        >
          <span class="text-3xl">*</span>
          <span>{item.title}</span>
        </a>
      ))
    }
  </section>
</div>
