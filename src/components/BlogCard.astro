---
import { format } from "date-fns";

export interface Props {
  title: string;
  description: string;
  publishDate: Date;
  readingTime: string;
  tags: string[];
  slug: string;
}

const { title, description, publishDate, readingTime, tags, slug } =
  Astro.props;
---

<a
  href={`/blog/${slug}`}
  class="block group card-hover bg-foreground/5 backdrop-blur-sm border border-foreground/10 rounded-lg p-6 transition-all duration-300"
>
  <div class="flex flex-col gap-3">
    <h3
      class="text-2xl font-semibold group-hover:text-blue-400 transition-colors"
    >
      {title}
    </h3>

    <p class="text-foreground/70 line-clamp-3">
      {description}
    </p>

    <div class="flex items-center gap-4 text-sm text-foreground/60">
      <time datetime={publishDate.toISOString()}>
        {format(publishDate, "MMM d, yyyy")}
      </time>
      <span>•</span>
      <span>{readingTime}</span>
    </div>

    <div class="flex flex-wrap gap-2">
      {
        tags.map((tag) => (
          <span class="px-2 py-1 bg-blue-400/10 text-blue-400 text-xs rounded-md">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</a>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
