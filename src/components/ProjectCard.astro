---
export interface Props {
  thumbnail: string;
  title: string;
  description: string;
  tags: string[];
  slug: string;
  githubUrl?: string;
  liveUrl?: string;
}

const { thumbnail, title, description, tags, slug, githubUrl, liveUrl } =
  Astro.props;
---

<a
  href={`/projects/${slug}`}
  class="group card-hover block bg-foreground/5 backdrop-blur-sm border border-foreground/10 rounded-lg overflow-hidden transition-all duration-300"
>
  <div class="aspect-video w-full overflow-hidden">
    <img
      src={thumbnail}
      alt={title}
      class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-300"
    />
  </div>

  <div class="p-6 flex flex-col gap-3">
    <h3
      class="text-xl font-semibold group-hover:text-blue-400 transition-colors"
    >
      {title}
    </h3>

    <p class="text-foreground/70 text-sm line-clamp-2">
      {description}
    </p>

    <div class="flex flex-wrap gap-2">
      {
        tags.map((tag) => (
          <span class="px-2 py-1 bg-blue-400/10 text-blue-400 text-xs rounded-md">
            {tag}
          </span>
        ))
      }
    </div>

    <div class="flex gap-3 mt-2">
      {
        githubUrl && (
          <span class="text-sm text-foreground/60 hover:text-blue-400 transition-colors">
            GitHub →
          </span>
        )
      }
      {
        liveUrl && (
          <span class="text-sm text-foreground/60 hover:text-blue-400 transition-colors">
            Live Demo →
          </span>
        )
      }
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
