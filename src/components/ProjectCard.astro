---
export interface Props {
  thumbnail: string;
  title: string;
  description: string;
  tags: string[];
  slug: string;
  githubUrl?: string;
  liveUrl?: string;
}

const { thumbnail, title, description, tags, slug, githubUrl, liveUrl } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class="group card-hover flex flex-col glass rounded-xl overflow-hidden border border-border"
>
  <div class="aspect-video w-full overflow-hidden bg-surface-2">
    <img
      src={thumbnail}
      alt={title}
      class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500 opacity-90 group-hover:opacity-100"
    />
  </div>

  <div class="p-5 flex flex-col gap-3 flex-1">
    <h3 class="text-base font-semibold text-foreground/90 group-hover:text-accent transition-colors leading-snug">
      {title}
    </h3>

    <p class="text-sm text-muted line-clamp-2 leading-relaxed flex-1">
      {description}
    </p>

    <div class="flex flex-wrap gap-1.5 mt-1">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <div class="flex gap-4 pt-1 border-t border-border mt-1">
      {githubUrl && (
        <span class="text-xs text-muted group-hover:text-accent transition-colors font-medium">
          GitHub ↗
        </span>
      )}
      {liveUrl && (
        <span class="text-xs text-muted group-hover:text-accent-blue transition-colors font-medium">
          Live Demo ↗
        </span>
      )}
      {!githubUrl && !liveUrl && (
        <span class="text-xs text-muted/50">View project →</span>
      )}
    </div>
  </div>
</a>
