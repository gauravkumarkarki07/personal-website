---
import { Image } from "astro:assets";
import SnevicWebsite from "../assets/snevic-website.png";
import GithubIcon from "../assets/github-icon.svg";

export interface Props {
  img: typeof SnevicWebsite;
  title: string;
  slug: string;
  githubLink?: string;
  liveLink?: string;
}

const { slug, title, img, githubLink, liveLink } = Astro.props;
---

<section
  class="flex flex-col bg-white text-black w-full max-w-[350px] h-[500px] p-2 border rounded-lg md:h-[380px]"
>
  <div class="w-full h-[60%]">
    <Image
      src={img}
      alt={title}
      class="object-fill w-full h-full border rounded-lg border-gray-300"
    />
  </div>
  <div class="flex flex-col flex-1">
    <h1 class="text-xl font-bold mt-2">{title}</h1>
    <p class="text-sm text-gray-500">{slug}</p>
  </div>

  <section class="flex flex-row items-center justify-between">
    <section class="flex flex-row gap-4 items-center">
      {
        githubLink && (
          <a
            href="https://github.com/gauravkumarkarki07"
            aria-label="GitHub Profile"
            target="_blank"
            rel="noopener noreferrer"
          >
            <GithubIcon class={"fill-black w-4 h-4"} />
          </a>
        )
      }
    </section>

    <button class="hover:scale-105 hover:cursor-pointer"> View Details </button>
  </section>
</section>
